### 1️⃣4️⃣ TEST GET TENANT BY ID API
#######################################

### Get tenant by ID (SUCCESS - OWNER)
GET {{baseUrl}}/api/tenants/698dc93abb72c6ab681bc0ce
Authorization: Bearer {{owner_token}}

###
# EXPECT: 200 OK
# Response sẽ có thông tin chi tiết của tenant với user và room info
###

### Get tenant by ID (SUCCESS - OWNER - WITH POPULATED DATA)
GET {{baseUrl}}/api/tenants/698dc93abb72c6ab681bc0ce
Authorization: Bearer {{owner_token}}

###
# EXPECT: 200 OK
# Response sẽ có:
# - userId: { name, email, phone, cccdImages }
# - roomId: { number, floor, buildingId: { name, address } }
# - status, moveInDate, contractEndDate, emergencyContact
###

### Get tenant by ID (TENANT - FORBIDDEN)
GET {{baseUrl}}/api/tenants/698dc93abb72c6ab681bc0ce
Authorization: Bearer {{tenant_token}}

###
# EXPECT: 403 Forbidden
# Chỉ OWNER mới có thể xem chi tiết tenant
###

### Get tenant by ID (INVALID ID - ERROR)
GET {{baseUrl}}/api/tenants/invalid-id
Authorization: Bearer {{owner_token}}

###
# EXPECT: 400 Bad Request
# Response: {"message": "Invalid tenant id"}
###

### Get tenant by ID (NOT FOUND - ERROR)
GET {{baseUrl}}/api/tenants/507f1f77bcf86cd799439011
Authorization: Bearer {{owner_token}}

###
# EXPECT: 404 Not Found
# Response: {"message": "Tenant not found"}
###

### Get tenant by ID (WITHOUT AUTH - FAIL)
GET {{baseUrl}}/api/tenants/698dc93abb72c6ab681bc0ce

###
# EXPECT: 401 Unauthorized
###
